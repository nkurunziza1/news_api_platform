{
  "name": "news-platform-api",
  "version": "1.0.0",
  "description": "RESTful API for News Platform (Medium-style)",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
